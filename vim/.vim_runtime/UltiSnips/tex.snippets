# https://castel.dev/post/lecture-notes-1/

# box for box
snippet box "Box"
`!p snip.rv = '‚îå' + '‚îÄ' * (len(t[1]) + 2) + '‚îê'`
‚îÇ $1 ‚îÇ
`!p snip.rv = '‚îî' + '‚îÄ' * (len(t[1]) + 2) + '‚îò'`
$0
endsnippet

# beg for \begin{...}
snippet beg "begin{} / end{}" bA
\begin{$1}
	$0
\end{$1}
endsnippet

# mk for inline math
snippet mk "Math" wA
$${1}$`!p
if t[2] and t[2][0] not in [',', '.', '?', '-', ' ']:
    snip.rv = ' '
else:
    snip.rv = ''
`$2
endsnippet

# dm for display math
snippet dm "Math" wA
\[
$1
.\] $0
endsnippet

# subscripts
snippet '([A-Za-z])(\d)' "auto subscript" wrA
`!p snip.rv = match.group(1)`_`!p snip.rv = match.group(2)`
endsnippet
snippet '([A-Za-z])_(\d\d)' "auto subscript2" wrA
`!p snip.rv = match.group(1)`_{`!p snip.rv = match.group(2)`}
endsnippet

# supersripts
snippet '([A-Za-z])^(\d\d)' "auto superscript" wrA
`!p snip.rv = match.group(1)`_{`!p snip.rv = match.group(2)`}
endsnippet

